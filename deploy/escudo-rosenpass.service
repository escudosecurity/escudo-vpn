[Unit]
Description=Rosenpass Quantum-Resistant Key Exchange for Escudo VPN
After=network.target wg-quick@wg0.service
Wants=wg-quick@wg0.service

[Service]
Type=simple
ExecStart=/usr/local/bin/rosenpass exchange-config /etc/escudo/rosenpass.toml
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
